{
  "$schema": "https://schema.spaceoperator.com/node-v2.schema.json",
  "version": "0.1",
  "name": "close_direct_recipient",
  "prefix": "rewards",
  "type": "native",
  "description": "Close a direct recipient account, returning rent to the original payer",
  "author_handle": "spo",
  "source_code": "crates/cmds-solana/src/rewards/close_direct_recipient.rs",
  "ports": {
    "inputs": [
      { "name": "recipient", "type_bounds": ["keypair"], "required": true, "passthrough": true, "tooltip": "Wallet of the recipient" },
      { "name": "original_payer", "type_bounds": ["pubkey"], "required": true, "tooltip": "Original payer of the recipient PDA; receives rent refund" },
      { "name": "distribution", "type_bounds": ["pubkey"], "required": true, "tooltip": "Direct distribution PDA" },
      { "name": "submit", "type_bounds": ["bool"], "tooltip": "Submit transaction to the network" }
    ],
    "outputs": [
      { "name": "signature", "type": "signature", "optional": true, "tooltip": "Transaction signature" }
    ]
  },
  "config_schema": {},
  "config": { "submit": { "B": true } },
  "classification": {
    "vendor": "Solana", "program": "rewards", "category": "defi",
    "icon_url": "https://github.com/solana-program.png",
    "tags": ["rewards", "direct", "recipient", "close"]
  },
  "external_version": {
    "program_id": "REWArDioXgQJ2fZKkfu9LCLjQfRwYWVVfsvcsR5hoXi",
    "sdk_crate": null, "sdk_version": null, "api_base_url": null, "api_version": null,
    "source_repo": "https://github.com/solana-program/rewards"
  },
  "internal": { "source": "crates", "source_code": "crates/cmds-solana/node-definitions/rewards/close_direct_recipient.jsonc", "repo": "flow-backend" }
}
