  "source_code": "crates/cmds-solana/src/rewards/close_merkle_claim.rs",
  "ports": {
    "inputs": [
      { "name": "claimant", "type_bounds": ["keypair"], "required": true, "passthrough": true, "tooltip": "Wallet of the claimant; receives rent refund" },
      { "name": "distribution", "type_bounds": ["pubkey"], "required": true, "tooltip": "Merkle distribution PDA" },
      { "name": "submit", "type_bounds": ["bool"], "tooltip": "Submit transaction to the network" }
    ],
    "outputs": [
      { "name": "signature", "type": "signature", "optional": true }
    ]
  },
  "config_schema": {},
  "config": { "submit": { "B": true } },
  "classification": {
    "vendor": "Solana", "program": "rewards", "category": "defi",
