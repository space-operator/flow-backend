{
  "$schema": "https://schema.spaceoperator.com/node-v2.schema.json",
  "version": "0.1",
  "name": "set_agent_token_v1",
  "prefix": "mpl_agent",
  "type": "native",
  "description": "Associate an agent token with an existing identity, upgrading V1 to V2",
  "author_handle": "spo",
  "source_code": "crates/cmds-solana/src/mpl_agent/set_agent_token_v1.rs",
  "ports": {
    "inputs": [
      {
        "name": "fee_payer",
        "type_bounds": ["keypair"],
        "required": true,
        "passthrough": true,
        "tooltip": "Account paying transaction fees"
      },
      {
        "name": "asset",
        "type_bounds": ["pubkey"],
        "required": true,
        "tooltip": "The Core asset with an existing agent identity"
      },
      {
        "name": "genesis_account",
        "type_bounds": ["pubkey"],
        "required": true,
        "tooltip": "The Genesis account for the agent's token launch"
      },
      {
        "name": "authority",
        "type_bounds": ["keypair"],
        "tooltip": "Asset signer authority. Defaults to fee_payer if not provided"
      },
      {
        "name": "submit",
        "type_bounds": ["bool"],
        "required": true,
        "tooltip": "Submit transaction to the network"
      }
    ],
    "outputs": [
      {
        "name": "signature",
        "type": "signature",
        "optional": true,
        "tooltip": "Transaction signature"
      },
      {
        "name": "agent_identity",
        "type": "pubkey",
        "tooltip": "Derived agent identity PDA"
      }
    ]
  },
  "config_schema": {},
  "config": {
    "submit": { "B": true }
  },
  "classification": {
    "vendor": "Metaplex",
    "program": "mpl_agent",
    "category": "agent",
    "icon_url": "https://github.com/metaplex-foundation.png",
    "tags": ["agent", "identity", "token"]
  },
  "external_version": {
    "program_id": "1DREGFgysWYxLnRnKQnwrxnJQeSMk2HmGaC6whw2B2p",
    "sdk_crate": "mpl-agent-identity",
    "sdk_version": "0.2.1",
    "api_base_url": null,
    "api_version": null,
    "source_repo": "https://github.com/metaplex-foundation/mpl-agent"
  },
  "internal": {
    "source": "crates",
    "source_code": "crates/cmds-solana/node-definitions/mpl_agent/set_agent_token_v1.jsonc",
    "repo": "flow-backend"
  }
}
