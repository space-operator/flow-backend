{
  "$schema": "https://schema.spaceoperator.com/node-v2.schema.json",
  "version": "0.1",
  "name": "revoke_execution_v1",
  "prefix": "mpl_agent",
  "type": "native",
  "description": "Revoke delegated execution permissions and refund rent",
  "author_handle": "spo",
  "source_code": "crates/cmds-solana/src/mpl_agent/revoke_execution_v1.rs",
  "ports": {
    "inputs": [
      {
        "name": "fee_payer",
        "type_bounds": ["keypair"],
        "required": true,
        "passthrough": true,
        "tooltip": "Account paying transaction fees"
      },
      {
        "name": "executive_authority",
        "type_bounds": ["pubkey"],
        "required": true,
        "tooltip": "The executive authority pubkey (used to derive executive_profile and delegation record PDAs)"
      },
      {
        "name": "agent_asset",
        "type_bounds": ["pubkey"],
        "required": true,
        "tooltip": "The agent Core asset address"
      },
      {
        "name": "destination",
        "type_bounds": ["pubkey"],
        "tooltip": "Account to receive refunded rent. Defaults to fee_payer"
      },
      {
        "name": "authority",
        "type_bounds": ["keypair"],
        "tooltip": "Asset owner or executive authority signer. Defaults to fee_payer"
      },
      {
        "name": "submit",
        "type_bounds": ["bool"],
        "required": true,
        "tooltip": "Submit transaction to the network"
      }
    ],
    "outputs": [
      {
        "name": "signature",
        "type": "signature",
        "optional": true,
        "tooltip": "Transaction signature"
      },
      {
        "name": "execution_delegate_record",
        "type": "pubkey",
        "tooltip": "Derived execution delegate record PDA that was closed"
      }
    ]
  },
  "config_schema": {},
  "config": {
    "submit": { "B": true }
  },
  "classification": {
    "vendor": "Metaplex",
    "program": "mpl_agent",
    "category": "agent",
    "icon_url": "https://github.com/metaplex-foundation.png",
    "tags": ["agent", "tools", "revoke"]
  },
  "external_version": {
    "program_id": "TLREGni9ZEyGC3vnPZtqUh95xQ8oPqJSvNjvB7FGK8S",
    "sdk_crate": "mpl-agent-tools",
    "sdk_version": "0.2.0",
    "api_base_url": null,
    "api_version": null,
    "source_repo": "https://github.com/metaplex-foundation/mpl-agent"
  },
  "internal": {
    "source": "crates",
    "source_code": "crates/cmds-solana/node-definitions/mpl_agent/revoke_execution_v1.jsonc",
    "repo": "flow-backend"
  }
}
